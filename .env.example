# ── Platform Foundation Environment Variables ──────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ── Google Cloud APIs ──────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key

# ── Anthropic (Safety & Classification) ────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Supabase (Database & RLS) ─────────────────────────────────────────
# Project URL — safe for browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — safe for browser, RLS enforces data isolation
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — NEVER expose to browser. Server-side only.
# Bypasses RLS — used for admin operations, migrations, background jobs.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── AWS Cognito (Authentication) ──────────────────────────────────────
# User Pool ID (e.g., us-east-1_VRyIcnOuP)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=your-cognito-user-pool-id

# App Client ID (e.g., 5pb44pg40irb5v5p0k2atl7brk)
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-cognito-client-id

# Region (e.g., us-east-1)
NEXT_PUBLIC_COGNITO_REGION=us-east-1

# ── Logging ────────────────────────────────────────────────────────────
# Options: error (default), warn, info, debug, silent
LOG_LEVEL=error

# ACRCloud — Song Identification (TASK-040)
ACRCLOUD_HOST=identify-us-west-2.acrcloud.com
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
SONG_ID_PROVIDER=mock
