# Platform Foundation — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to the repository

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get your key at: console.anthropic.com
# Use separate keys per environment:
#   platform-foundation-dev   → for local + develop branch
#   platform-foundation-staging → for staging branch
#   platform-foundation-prod  → for production (main branch)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Cloud ─────────────────────────────────────────────────────────────
# Get your key at: console.cloud.google.com
# Required APIs: Cloud Translation API + Cloud Text-to-Speech API
# Use separate keys per environment:
#   platform-foundation-dev   → for local + develop branch
#   platform-foundation-staging → for staging branch
#   platform-foundation-prod  → for production (main branch)
GOOGLE_API_KEY=AIzaSy...

# ─── Environment ──────────────────────────────────────────────────────────────
# Options: development | staging | production
NODE_ENV=development

# ─── Environment URLs ─────────────────────────────────────────────────────────
# Local:      http://localhost:3000
# Dev:        https://platform-foundation-dev.vercel.app      (develop branch)
# Staging:    https://platform-foundation-staging.vercel.app  (staging branch)
# Production: https://platform-foundation-inky.vercel.app     (main branch)
